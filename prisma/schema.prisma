// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// For Supabase, we use PostgreSQL and the Transaction Pooler (pgbouncer=true string)
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------
// Multi-tenant Models
// ---------------------------------------------

model Shop {
  id        String   @id
  name      String
  slug      String
  businessType BusinessType @default(BARBERIA)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Landing page personalization (optional)
  logoUrl       String?
  tagline       String?
  description   String?
  address       String?
  whatsappPhone String?
  instagramUrl  String?
  facebookUrl   String?

  // Relationships
  memberships  ShopMember[]
  services     Service[]
  appointments Appointment[]
  schedules    ShopSchedule[]
}

// Users are tied to Supabase Auth by `id`
model User {
  id        String   @id @db.Uuid @default(dbgenerated("uuid_generate_v4()"))
  email     String   @unique
  name      String?
  phone     String?
  role      Role     @default(CUSTOMER) // Global role (e.g. SUPER_ADMIN)
  needsPasswordChange Boolean @default(false)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  memberships            ShopMember[]
  appointmentsAsStaff    Appointment[] @relation("StaffAppointments")
  appointmentsAsCustomer Appointment[] @relation("CustomerAppointments")
}

model ShopMember {
  id        String   @id @default(cuid())
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  
  role      Role     @default(CUSTOMER) // Local role within this shop
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, shopId]) // A user can only have one role per shop
}

enum Role {
  SUPER_ADMIN
  OWNER
  STAFF
  CUSTOMER
}

enum BusinessType {
  BARBERIA
  SALON_BELLEZA
  SPA
  CLINICA
}

model ShopSchedule {
  id           String  @id @default(cuid())
  shopId       String
  shop         Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  dayOfWeek    Int     // 0=Sunday, 1=Monday ... 6=Saturday
  openTime     String  // "09:00"
  closeTime    String  // "18:00"
  slotDuration Int     @default(30) // minutes
  isOpen       Boolean @default(true)

  @@unique([shopId, dayOfWeek])
}

model Service {
  id          String   @id
  name        String
  description String?
  price       Float
  duration    Int      // Duration in minutes
  
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relationships
  appointments Appointment[]
}

model Appointment {
  id             String   @id @default(cuid())
  startTime      DateTime
  endTime        DateTime
  status         AppointmentStatus @default(PENDING)
  priceAtBooking Float?   // Snapshot of service price at booking time
  customerName   String?  // For guest bookings (no account)
  customerPhone  String?  // For guest bookings (no account)

  // Relationships
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  serviceId   String
  service     Service  @relation(fields: [serviceId], references: [id])

  staffId     String?  @db.Uuid
  staff       User?    @relation("StaffAppointments", fields: [staffId], references: [id])

  customerId  String?  @db.Uuid
  customer    User?    @relation("CustomerAppointments", fields: [customerId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([staffId, startTime])
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}
