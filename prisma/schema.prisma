generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Shop {
  id            String         @id
  name          String
  slug          String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  businessType  BusinessType   @default(BARBERIA)
  address       String?
  description   String?
  facebookUrl   String?
  instagramUrl  String?
  logoUrl       String?
  tagline       String?
  whatsappPhone String?
  appointments  Appointment[]
  services      Service[]
  memberships   ShopMember[]
  schedules     ShopSchedule[]
}

model User {
  id                     String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  email                  String        @unique
  name                   String?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  phone                  String?
  needsPasswordChange    Boolean       @default(false)
  appointmentsAsCustomer Appointment[] @relation("CustomerAppointments")
  appointmentsAsStaff    Appointment[] @relation("StaffAppointments")
  memberships            ShopMember[]
}

model ShopMember {
  id        String   @id @default(cuid())
  userId    String   @db.Uuid
  shopId    String
  role      Role     @default(CUSTOMER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, shopId])
}

model ShopSchedule {
  id           String  @id @default(cuid())
  shopId       String
  dayOfWeek    Int
  openTime     String
  closeTime    String
  slotDuration Int     @default(30)
  isOpen       Boolean @default(true)
  shop         Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, dayOfWeek])
}

model Service {
  id                String        @id
  name              String
  description       String?
  price             Float
  duration          Int
  shopId            String
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  appointments      Appointment[] @relation("LegacyService")
  shop              Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  multiAppointments Appointment[] @relation("AppointmentServices")
}

model Appointment {
  id             String            @id @default(cuid())
  startTime      DateTime
  endTime        DateTime
  status         AppointmentStatus @default(PENDING)
  shopId         String
  serviceId      String?
  staffId        String?           @db.Uuid
  customerId     String?           @db.Uuid
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  customerName   String?
  customerPhone  String?
  priceAtBooking Float?
  customer       User?             @relation("CustomerAppointments", fields: [customerId], references: [id])
  service        Service?          @relation("LegacyService", fields: [serviceId], references: [id])
  shop           Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)
  staff          User?             @relation("StaffAppointments", fields: [staffId], references: [id])
  services       Service[]         @relation("AppointmentServices")

  @@index([staffId, startTime])
}

enum Role {
  SUPER_ADMIN
  OWNER
  STAFF
  CUSTOMER
}

enum BusinessType {
  BARBERIA
  SALON_BELLEZA
  SPA
  CLINICA
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}
